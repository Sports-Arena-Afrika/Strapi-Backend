{
  "kind": "collectionType",
  "collectionName": "podcasts",
  "info": {
    "singularName": "podcast",
    "pluralName": "podcasts",
    "displayName": "Podcast"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "show": {
      "type": "string",
      "required": true
    },
    "date": {
      "type": "datetime"
    },
    "duration": {
      "type": "integer",
      "required": false
    },
    "description": {
      "type": "text",
      "required": true
    },
    "featured": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "cover": {
      "type": "component",
      "component": "shared.media",
      "repeatable": false,
      "required": true
    },
    "providers": {
      "type": "component",
      "component": "shared.provider-link",
      "repeatable": true,
      "required": true
    },
    "category": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::category.category"
    },
    "hosts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::host.host",
      "mappedBy": "podcasts"
    },
    "episodes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::episode.episode",
      "mappedBy": "podcast"
    },
    "tags": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tag.tag"
    }
  }
}
