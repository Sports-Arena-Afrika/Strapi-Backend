{
  "kind": "collectionType",
  "collectionName": "leagues",
  "info": {
    "singularName": "league",
    "pluralName": "leagues",
    "displayName": "League"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
