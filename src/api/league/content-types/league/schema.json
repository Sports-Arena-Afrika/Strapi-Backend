      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "abbreviation": {
      "type": "string"
    },
    "eventLength": {
      "type": "integer"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "leagues"
    },
    "predictions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::prediction.prediction",
      "mappedBy": "league"
    }
  }
}
