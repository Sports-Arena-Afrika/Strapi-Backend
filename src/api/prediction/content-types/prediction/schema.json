{
  "kind": "collectionType",
  "collectionName": "predictions",
  "info": {
    "singularName": "prediction",
    "pluralName": "predictions",
    "displayName": "Prediction"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "league": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::league.league",
      "inversedBy": "predictions"
    },
    "homeTeam": {
      "type": "component",
      "component": "shared.team",
      "repeatable": false
    },
    "awayTeam": {
      "type": "component",
      "component": "shared.team",
      "repeatable": false
    },
    "kickoff": {
      "type": "datetime",
      "required": true
    },
    "confidence": {
      "type": "integer",
      "required": true
    },
    "analyst": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "predictions"
    },
    "insight": {
      "type": "text",
      "required": true
    },
    "fullInsight": {
      "type": "text"
    },
    "correct": {
      "type": "boolean"
    },
    "featured": {
      "type": "boolean",
      "required": true,
      "default": false
    }
  }
}
